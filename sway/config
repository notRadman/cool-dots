### Main variables ###
set $mod Mod1
set $term tilix
#set $menu bemenu-run -b -fn "JetBrains Mono:size=14"
set $menu fuzzel

### Includes ###
include ./local.d/*.conf

### Keyboard ###
input type:keyboard {
    xkb_layout us,ara
    xkb_options grp:lwin_toggle,lv3:ralt_alt
    repeat_delay 300
    repeat_rate 50
}

### Touchpad ###
input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
}

### screen ###

# Background
#output * bg ~/wallpaper.jpg fill

# Auto resolution (can change it based on screen and you can get infotmation by swaymsg -t get_outputs)
output LVDS-2 resolution 1366x768@60.015Hz position 0,0

# eye saver
bindsym --to-code $mod+Shift+e exec pkill wlsunset || wlsunset -l 31.5 -L 34.47 -t 3700 -T 6499

# Font
font pango: Noto Sans Mono 11
#font pango:JetBrains Mono 11, Cairo 11, Noto Sans Mono 11, Font Awesome 6 Free 11

### Main keybindings ###

# Terminal
bindsym --to-code $mod+Return exec $term

# Application Launcher
bindsym --to-code $mod+d exec $menu

# Kill Window
bindsym --to-code $mod+Shift+q kill

# Reload Config
bindsym --to-code $mod+Shift+Control+c reload

# Exit Sway
bindsym --to-code $mod+Shift+Control+q exit

### Sound Control ###
bindsym --to-code XF86AudioRaiseVolume exec wpctl set-volume -l 1.1 @DEFAULT_SINK@ 5%+
bindsym --to-code XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_SINK@ 5%-
bindsym --to-code XF86AudioMute exec wpctl set-mute @DEFAULT_SINK@ toggle

### Clipboard(near line 36) ###
# Show the clipboard
bindsym --to-code $mod+c exec clipman pick -t STDOUT | fuzzel --dmenu --prompt='📋 ' | wl-copy
# Empty the clipboard
bindsym --to-code $mod+Shift+c exec clipman clear --all && notify-send "Clipman" "History cleared! 🗑️"

### Screenshots ###

# Whole screen
bindsym --to-code $mod+bracketright exec bash -c 'mkdir -p ~/Pictures/Screenshots && f=~/Pictures/Screenshots/screenshot-$(date +%Y%m%d-%H%M%S).png && grim "$f" && notify-send "Screenshot ✓" "Saved: $(basename $f)" -i camera-photo'

# Specific area
bindsym --to-code $mod+shift+bracketright exec bash -c 'mkdir -p ~/Pictures/Screenshots && f=~/Pictures/Screenshots/screenshot-$(date +%Y%m%d-%H%M%S).png && grim -g "$(slurp)" "$f" && notify-send "Screenshot ✓" "Saved: $(basename $f)" -i camera-photo'

### Screen Lock ###
bindsym --to-code $mod+semicolon exec swaylock -f -c 000000

### Window Navigation (like i3) ###

# Focus
bindsym --to-code $mod+h focus left
bindsym --to-code $mod+j focus down
bindsym --to-code $mod+k focus up
bindsym --to-code $mod+l focus right
# Move
bindsym --to-code $mod+Shift+h move left
bindsym --to-code $mod+Shift+j move down
bindsym --to-code $mod+Shift+k move up
bindsym --to-code $mod+Shift+l move right
### Workspaces ###
bindsym --to-code $mod+1 workspace number 1
bindsym --to-code $mod+2 workspace number 2
bindsym --to-code $mod+3 workspace number 3
bindsym --to-code $mod+4 workspace number 4
bindsym --to-code $mod+5 workspace number 5
bindsym --to-code $mod+6 workspace number 6
bindsym --to-code $mod+7 workspace number 7
bindsym --to-code $mod+8 workspace number 8
bindsym --to-code $mod+9 workspace number 9
bindsym --to-code $mod+0 workspace number 10
# Move to workspace
bindsym --to-code $mod+Shift+1 move container to workspace number 1
bindsym --to-code $mod+Shift+2 move container to workspace number 2
bindsym --to-code $mod+Shift+3 move container to workspace number 3
bindsym --to-code $mod+Shift+4 move container to workspace number 4
bindsym --to-code $mod+Shift+5 move container to workspace number 5
bindsym --to-code $mod+Shift+6 move container to workspace number 6
bindsym --to-code $mod+Shift+7 move container to workspace number 7
bindsym --to-code $mod+Shift+8 move container to workspace number 8
bindsym --to-code $mod+Shift+9 move container to workspace number 9
bindsym --to-code $mod+Shift+0 move container to workspace number 10

### Layout ###

# Split horizontal
bindsym --to-code $mod+b splith

# Split vertical
bindsym --to-code $mod+v splitv

# Stacking
bindsym --to-code $mod+s layout stacking

# Tabbed
bindsym --to-code $mod+w layout tabbed

# Toggle split
bindsym --to-code $mod+e layout toggle split

# Fullscreen
bindsym --to-code $mod+f fullscreen

# Toggle floating
bindsym --to-code $mod+Shift+space floating toggle

# Focus floating/tiling
bindsym --to-code $mod+space focus mode_toggle

# Focus parent
bindsym --to-code $mod+a focus parent

### Resizing ###
mode "resize" {
    bindsym --to-code Left resize shrink width 10px
    bindsym --to-code Down resize grow height 10px
    bindsym --to-code Up resize shrink height 10px
    bindsym --to-code Right resize grow width 10px
    bindsym --to-code h resize shrink width 10px
    bindsym --to-code j resize grow height 10px
    bindsym --to-code k resize shrink height 10px
    bindsym --to-code l resize grow width 10px
    bindsym --to-code Return mode "default"
    bindsym --to-code Escape mode "default"
}
bindsym --to-code $mod+r mode "resize"

